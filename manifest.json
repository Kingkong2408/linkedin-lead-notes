{
  "manifest_version": 3,
  "name": "LinkedIn Lead Notes",
  "version": "1.0.0",
  "description": "Save private notes on LinkedIn profiles and export leads to CSV.",
  "permissions": ["storage"],
  "host_permissions": ["https://www.linkedin.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.linkedin.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "action": {
    "default_title": "LinkedIn Lead Notes",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}